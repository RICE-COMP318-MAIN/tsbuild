{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tsbuild Config",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema URL for validation"
    },
    "entry": {
      "type": "string",
      "description": "Entry point file"
    },
    "output": {
      "type": "string",
      "description": "Output bundle file"
    },
    "copy": {
      "type": "array",
      "description": "Directories to copy",
      "items": {
        "type": "object",
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" }
        },
        "required": ["from", "to"],
        "additionalProperties": false
      }
    }
  },
  "required": ["entry", "output"],
  "additionalProperties": false
}
