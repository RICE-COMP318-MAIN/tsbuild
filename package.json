{
    "name": "tsbuild",
    "version": "0.1.0",
    "description": "Build tool for COMP 318 TypeScript projects.",
    "keywords": [
        "esbuild",
        "COMP 318"
    ],
    "homepage": "https://github.com/RICE-COMP318-MAIN/tsbuild#readme",
    "bugs": {
        "url": "https://github.com/RICE-COMP318-MAIN/tsbuild/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/RICE-COMP318-MAIN/tsbuild.git"
    },
    "license": "BSD-3-Clause",
    "author": "Scott Rixner",
    "bin": {
        "tsbuild": "dist/tsbuild"
    },
    "exports": {
        ".": "./dist/loadenv.js"
    },
    "types": "dist/tsbuild.d.ts",
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "node scripts/build.mjs",
