        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "devDependencies": {
        "@babel/preset-typescript": "^7.27.1",
        "@biomejs/biome": "^1.9.4",
        "@types/istanbul-lib-instrument": "^1.7.7",
        "@types/node": "^24.0.1",
        "rimraf": "^6.0.1",
        "typescript": "^5.8.3"
    },
    "dependencies": {
        "ajv": "^8.17.1",
        "chokidar": "^4.0.3",
        "dotenv": "^16.5.0",
        "esbuild": "^0.25.5",
        "istanbul-lib-instrument": "^6.0.3"
    }
}
